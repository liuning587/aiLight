{
  "version": 1,
  "hooks": {
    "sessionStart": [
      {
        "command": "python .cursor/hooks/ailight_hook.py session_start",
        "timeout": 10
      }
    ],
    "stop": [
      {
        "command": "python .cursor/hooks/ailight_hook.py session_stop",
        "timeout": 10
      }
    ],
    "beforeSubmitPrompt": [
      {
        "command": "python .cursor/hooks/ailight_hook.py prompt",
        "matcher": "UserPromptSubmit",
        "timeout": 10
      }
    ],
    "beforeShellExecution": [
      {
        "command": "python .cursor/hooks/ailight_hook.py permission_wait",
        "timeout": 8
      }
    ],
    "afterShellExecution": [
      {
        "command": "python .cursor/hooks/ailight_hook.py permission_done",
        "timeout": 8
      }
    ],
    "beforeMCPExecution": [
      {
        "command": "python .cursor/hooks/ailight_hook.py permission_wait",
        "timeout": 8
      }
    ],
    "afterMCPExecution": [
      {
        "command": "python .cursor/hooks/ailight_hook.py permission_done",
        "timeout": 8
      }
    ],
    "preToolUse": [
      {
        "command": "python .cursor/hooks/ailight_hook.py tool_start",
        "matcher": "Shell|Write|Task",
        "timeout": 8
      }
    ],
    "postToolUse": [
      {
        "command": "python .cursor/hooks/ailight_hook.py tool_success",
        "matcher": "Shell|Write|Task",
        "timeout": 8
      }
    ],
    "postToolUseFailure": [
      {
        "command": "python .cursor/hooks/ailight_hook.py tool_failure",
        "timeout": 10
      }
    ]
  }
}
